# Accepts postgres://, postgresql://, or postgresql+asyncpg:// — driver prefix is normalised automatically.
# Railway provides this automatically when you attach a Postgres service.
DATABASE_URL=postgresql://procura:procura@localhost:5432/procura

SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENROUTER_API_KEY=sk-or-...
APP_URL=http://localhost:3000
UPLOAD_DIR=uploads
DEBUG=false

# Optional — enable LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=procura
